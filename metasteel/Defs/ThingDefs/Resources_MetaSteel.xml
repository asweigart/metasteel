<?xml version="1.0" encoding="utf-8"?>
<Defs>

  <ThingDef Abstract="True" Name="MetaSteelBase" ParentName="ResourceBase">
    <thingCategories>
      <li>ResourcesRaw</li>
    </thingCategories>
    <graphicData>
      <texPath>Things/Item/Resource/Steel</texPath>
      <graphicClass>Graphic_StackCount</graphicClass>
    </graphicData>
    <soundInteract>Metal_Drop</soundInteract>
    <soundDrop>Metal_Drop</soundDrop>
    <stackLimit>75</stackLimit>
    <healthAffectsPrice>false</healthAffectsPrice>
    <tradeability>Sellable</tradeability>
    <statBases>
      <Flammability>0</Flammability>
      <DeteriorationRate>0</DeteriorationRate>
      <Beauty>-4</Beauty>
    </statBases>
    <stuffProps>
      <categories>
        <li>Metallic</li>
      </categories>
      <commonality>0</commonality>
      <constructEffect>ConstructMetal</constructEffect>
      <appearance>Metal</appearance>
      <soundImpactStuff>BulletImpact_Metal</soundImpactStuff>
      <soundMeleeHitSharp>MeleeHit_Metal_Sharp</soundMeleeHitSharp>
      <soundMeleeHitBlunt>MeleeHit_Metal_Blunt</soundMeleeHitBlunt>
      <statFactors>
        <Beauty>0.5</Beauty>
        <DoorOpenSpeed>1.45</DoorOpenSpeed>
      </statFactors>
    </stuffProps>
  </ThingDef>

  <ThingDef ParentName="MetaSteelBase">
    <defName>MetaSteel</defName>
    <label>metasteel</label>
    <description>An unnaturally dense allotrope of steel, coaxed out of ten ordinary ingots through a forging procedure that no living metallurgist fully understands. The recipe survives only as marginalia in a half-burnt notebook; smiths who follow it report that the final ingot weighs slightly more than the steel that went into it.</description>
    <graphicData>
      <texPath>Things/Item/Resource/MetaSteel</texPath>
      <graphicClass>Graphic_Single</graphicClass>
    </graphicData>
    <statBases>
      <MarketValue>3.6</MarketValue>
      <MaxHitPoints>100</MaxHitPoints>
    </statBases>
    <stuffProps>
      <stuffAdjective>metasteel</stuffAdjective>
      <color>(175, 185, 200)</color>
      <statFactors>
        <MaxHitPoints>2</MaxHitPoints>
        <MarketValue>2</MarketValue>
        <MeleeWeapon_DamageMultiplier>2</MeleeWeapon_DamageMultiplier>
      </statFactors>
      <statOffsets>
        <StuffPower_Armor_Sharp>1.4</StuffPower_Armor_Sharp>
        <StuffPower_Armor_Blunt>0.9</StuffPower_Armor_Blunt>
        <StuffPower_Armor_Heat>0.8</StuffPower_Armor_Heat>
        <StuffPower_Insulation_Cold>8</StuffPower_Insulation_Cold>
      </statOffsets>
    </stuffProps>
  </ThingDef>

  <ThingDef ParentName="MetaSteelBase">
    <defName>MetaMetaSteel</defName>
    <label>metametasteel</label>
    <description>Steel folded upon folded steel. A hundred units of raw steel are consumed to produce a single ingot, most of the mass apparently lost to a process the surviving notes describe only as "thinning." Pieces of metametasteel hum faintly when struck.</description>
    <graphicData>
      <texPath>Things/Item/Resource/MetaMetaSteel</texPath>
      <graphicClass>Graphic_Single</graphicClass>
    </graphicData>
    <statBases>
      <MarketValue>7.2</MarketValue>
      <MaxHitPoints>200</MaxHitPoints>
    </statBases>
    <stuffProps>
      <stuffAdjective>metametasteel</stuffAdjective>
      <color>(210, 220, 232)</color>
      <statFactors>
        <MaxHitPoints>4</MaxHitPoints>
        <MarketValue>4</MarketValue>
        <MeleeWeapon_DamageMultiplier>4</MeleeWeapon_DamageMultiplier>
      </statFactors>
      <statOffsets>
        <StuffPower_Armor_Sharp>2.8</StuffPower_Armor_Sharp>
        <StuffPower_Armor_Blunt>1.8</StuffPower_Armor_Blunt>
        <StuffPower_Armor_Heat>1.6</StuffPower_Armor_Heat>
        <StuffPower_Insulation_Cold>16</StuffPower_Insulation_Cold>
      </statOffsets>
    </stuffProps>
  </ThingDef>

  <ThingDef ParentName="MetaSteelBase">
    <defName>MetaMetaMetaSteel</defName>
    <label>metametametasteel</label>
    <description>The deepest known stage of the recursion. A thousand units of raw steel are sacrificed for one finished ingot; no two smiths describe the procedure the same way, and several refuse to discuss it at all. The result is so dense it seems to drink in the firelight.</description>
    <graphicData>
      <texPath>Things/Item/Resource/MetaMetaMetaSteel</texPath>
      <graphicClass>Graphic_Single</graphicClass>
    </graphicData>
    <statBases>
      <MarketValue>14.4</MarketValue>
      <MaxHitPoints>400</MaxHitPoints>
    </statBases>
    <stuffProps>
      <stuffAdjective>metametametasteel</stuffAdjective>
      <color>(240, 244, 250)</color>
      <statFactors>
        <MaxHitPoints>8</MaxHitPoints>
        <MarketValue>8</MarketValue>
        <MeleeWeapon_DamageMultiplier>8</MeleeWeapon_DamageMultiplier>
      </statFactors>
      <statOffsets>
        <StuffPower_Armor_Sharp>5.6</StuffPower_Armor_Sharp>
        <StuffPower_Armor_Blunt>3.6</StuffPower_Armor_Blunt>
        <StuffPower_Armor_Heat>3.2</StuffPower_Armor_Heat>
        <StuffPower_Insulation_Cold>32</StuffPower_Insulation_Cold>
      </statOffsets>
    </stuffProps>
  </ThingDef>

</Defs>
